# Supabase (get from your Supabase project settings)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Spotify app credentials (https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
SPOTIFY_REDIRECT_URI=http://localhost:3000/auth/callback

# Encryption key for Spotify refresh tokens stored in DB (any 32+ char random string)
REFRESH_TOKEN_SECRET=your-random-secret-min-32-chars

# App URL (set to production URL on Vercel)
NEXT_PUBLIC_APP_URL=http://localhost:3000
